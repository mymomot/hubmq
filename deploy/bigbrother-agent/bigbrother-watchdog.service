[Unit]
Description=BigBrother watchdog — fallback direct P0 si BigBrother silencieux
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=motreffs
Group=motreffs
Environment=HOME=/home/motreffs
Environment=PATH=/home/motreffs/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/home/motreffs/.bigbrother-agent/wrapper/bigbrother-watchdog.sh
StandardOutput=append:/home/motreffs/.bigbrother-agent/logs/watchdog-systemd.log
StandardError=append:/home/motreffs/.bigbrother-agent/logs/watchdog-systemd.log
NoNewPrivileges=yes
