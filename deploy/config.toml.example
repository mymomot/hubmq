[nats]
url = "nats://localhost:4222"
nkey_seed_path = "/etc/nats/nkeys/hubmq-service.seed"

[smtp]
host = "smtp.gmail.com"
port = 587
username = "mymomot74@gmail.com"
from = "HubMQ Lab <mymomot74@gmail.com>"
password_credential = "gmail-app-password"

[telegram]
allowed_chat_ids = []  # fill with your chat_id
token_credential = "telegram-bot-token"

[filter]
dedup_window_secs = 60
rate_limit_per_min = 10
rate_limit_p0_per_min = 100
quiet_hours_start = "22:00"
quiet_hours_end = "07:00"

[fallback]
email_to = "motreff@gmail.com"
heartbeat_silence_max_secs = 10800

[bridge]
msg_relay_url = "http://192.168.10.99:9480"
command_whitelist = ["status", "logs", "help"]
# bearer_credential : nom du credential systemd LoadCredential pour Authorization: Bearer.
# Si défini → /etc/hubmq/credentials/<name> doit exister (chmod 600 root:root). Sinon → headers absent → 401 si msg-relay exige auth.
bearer_credential = "msg-relay-token"

[ntfy]
# Phase Core: LAN only, empty = disabled
# base_url = "http://localhost:2586"
# topic = "hubmq-alerts"
# bearer_credential = "ntfy-bearer"

# ─── Source email IMAP — optionnelle (Phase 5.2) ────────────────────────────────
# Polling Gmail IMAP toutes les 30s. Désactivé par défaut (backward compat).
# Credential IMAP = même que smtp.password_credential (gmail-app-password).
#
# Commandes acceptées (sujet de l'email) :
#   HUBMQ_BOT_TOKEN <name>       → admin : ajout bot Telegram (token dans le body)
#   [<agent>] <message>          → message utilisateur vers l'agent (ex: [llmcore] explique CAP)
#   <agent>: <message>           → idem (ex: llmcore: explique CAP)
#
# Seuls les emails From: allowlisted sont traités — les autres sont ignorés silencieusement.
[email_source]
enabled = false
imap_host = "imap.gmail.com"
imap_port = 993
# username : réutilisé depuis [smtp].username (mymomot74@gmail.com)
# password_credential : réutilisé depuis [smtp].password_credential (gmail-app-password)
allowed_from = ["motreff@gmail.com"]
poll_interval_secs = 30
